      <table>
        <view>
          <datasources>
            <datasource caption='top1k_with_sector' name='federated.07hzdsn0sv9lp61ahmo981x85230' />
          </datasources>
          <datasource-dependencies datasource='federated.07hzdsn0sv9lp61ahmo981x85230'>
            <column caption='TEXT Revenue' datatype='string' name='[Calculation_1749366985157087238]' role='measure' type='nominal'>
              <calculation class='tableau' formula='&quot;₱&quot; + STR(INT(SUM([Revenue (million)]))) + &quot;M&quot;' />
            </column>
            <column datatype='string' name='[Company]' role='dimension' type='nominal' />
            <column datatype='string' name='[Industry]' role='dimension' type='nominal' />
