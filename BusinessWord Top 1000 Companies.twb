            <column-instance column='[Industry]' derivation='None' name='[none:Industry:nk]' pivot='key' type='nominal' />
            <column-instance column='[Revenue (million)]' derivation='Sum' name='[rank:sum:Revenue (million):qk:3]' pivot='key' type='quantitative'>
              <table-calc ordering-field='[federated.07hzdsn0sv9lp61ahmo981x85230].[Company]' ordering-type='Field' rank-options='Competition,Descending' type='Rank' />
            </column-instance>
            <column-instance column='[Revenue (million)]' derivation='Sum' name='[sum:Revenue (million):qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1749366985157087238]' derivation='User' name='[usr:Calculation_1749366985157087238:nk]' pivot='key' type='nominal' />
