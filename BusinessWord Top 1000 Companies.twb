      <aliases enabled='yes' />
      <column datatype='string' name='[Auditor]' role='dimension' type='nominal' />
      <column caption='SHORT TERM LOANS' datatype='integer' name='[Calculation_1717841787992186880]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL([Short Term Loans(million)]) THEN 0 ELSE [Short Term Loans(million)] END' />
      </column>
      <column caption='LONG TERM DEBT' datatype='integer' name='[Calculation_1717841787992379393]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL([Long Term Debt(millions)]) THEN 0 ELSE [Long Term Debt(millions)] END' />
      </column>
      <column caption='Rank by Revenue per Industry' datatype='integer' name='[Calculation_1717841788003876866]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_UNIQUE(SUM([Revenue (million)]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Calculation1' datatype='boolean' name='[Calculation_1717841788005810179]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK_UNIQUE(SUM([Revenue (million)]), &apos;desc&apos;) &lt;= [Parameters].[Parameter 1]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Rank per Industry' datatype='integer' name='[Calculation_1717841788009459716]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_UNIQUE(SUM([Revenue (million)]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top N filter' datatype='string' name='[Calculation_1717841788009877509]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1717841788009459716] &lt;= [Parameters].[Parameter 1] THEN &apos;Show&apos; ELSE &apos;Hide&apos; END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top 5 Companies by Industry' datatype='integer' name='[Calculation_1749366985141735424]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_UNIQUE(SUM([Revenue (million)]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top 5 Filter' datatype='real' name='[Calculation_1749366985141981185]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF RANK_UNIQUE(SUM([Revenue (million)]), &apos;desc&apos;) &lt;= THEN &apos;Top 5&apos; ELSE &apos;Other&apos; END' />
      </column>
      <column caption='TEXT Revenue' datatype='string' name='[Calculation_1749366985157087238]' role='measure' type='nominal'>
        <calculation class='tableau' formula='&quot;₱&quot; + STR(INT(SUM([Revenue (million)]))) + &quot;M&quot;' />
      </column>
      <column caption='Log of Revenue' datatype='real' name='[Calculation_1953717826975105024]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='LOG([Revenue (million)], 10)' />
      </column>
      <column caption='Debt-to-Equity' datatype='real' name='[Calculation_1953717826980110337]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Total Liabilities (million)]/ [Stockholders&apos; Equity(million)]' />
      </column>
      <column caption='Debt-to-Total Assets' datatype='real' name='[Calculation_1953717826981556226]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Total Liabilities (million)] / [Total Assets(million)]' />
      </column>
      <column caption='Current' datatype='real' name='[Calculation_1953717826982969352]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Current Assets(million)]/[Current Liabilities(million)]' />
      </column>
      <column caption='Total Asset Turnover ' datatype='real' name='[Calculation_1953717826983575561]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Net Sales(million)] / [Total Assets(million)]' />
      </column>
      <column caption='REVENUE LOG' datatype='real' name='[Calculation_1953717826998738954]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='LOG([Revenue (million)], 10)' />
      </column>
