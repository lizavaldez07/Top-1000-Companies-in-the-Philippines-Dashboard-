    <worksheet name='[Filter Industry] Top Companies by Revenue'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#ffffff' fontname='Tableau Medium'>Top Companies by Revenue</run>
          </formatted-text>
